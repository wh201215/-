---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { directions, resources } from "../../data/site";
---

<BaseLayout title="Archive" description="Raw resources grouped by the three active directions.">
  <section class="page-intro">
    <p class="eyebrow">Archive</p>
    <h1>Source Archive</h1>
    <p>
      All raw HTML and Markdown files stay here. The archive is now grouped by LLM Agents, Reinforcement Learning, and Recommendation Systems.
    </p>
  </section>

  {directions.map((direction) => {
    const current = resources.filter((item) => item.direction === direction.title);
    return (
      <section class="section">
        <div class="section-head">
          <p class="eyebrow">{direction.eyebrow}</p>
          <h2>{direction.title}</h2>
        </div>

        {current.length > 0 ? (
          <div class="resource-grid">
            {current.map((item) => (
              <article class="resource-card">
                <div class="resource-meta">
                  <span>{item.type}</span>
                  <span>{item.updated}</span>
                </div>
                <h3><a href={item.href} target="_blank" rel="noreferrer">{item.title}</a></h3>
                <p>{item.summary}</p>
              </article>
            ))}
          </div>
        ) : (
          <article class="content-card">
            <h2>No files yet</h2>
            <p>This direction already has a reserved slot. Later you can add recommendation HTML, Markdown, PDF, or PPT files here directly.</p>
          </article>
        )}
      </section>
    );
  })}
</BaseLayout>
