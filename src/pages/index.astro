---
import BaseLayout from "../layouts/BaseLayout.astro";
import { directions, resources } from "../data/site";

const recentResources = resources.slice(0, 6);
const totalCount = resources.length;
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Knowledge Directions</p>
      <h1>Three fixed tracks, one blue-white reading site, and a cleaner front page.</h1>
      <p class="lead">
        The homepage is no longer a generic blog feed. It now acts as an entry panel for your three active directions and the source archive behind them.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/notes">View directions</a>
        <a class="button button-secondary" href="/archive">Open archive</a>
      </div>
    </div>

    <aside class="hero-panel">
      <div class="hero-stat">
        <strong>3</strong>
        <span>Fixed directions</span>
      </div>
      <div class="hero-stat">
        <strong>{totalCount}</strong>
        <span>Archived resources</span>
      </div>
      <div class="hero-stat">
        <strong>Blue</strong>
        <span>Rethemed to match the blue-white tone of your existing HTML pages</span>
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Directions</p>
      <h2>Only these three directions stay on the front page for now</h2>
    </div>

    <div class="card-grid">
      {directions.map((direction) => (
        <a class="feature-card" href={direction.href}>
          <p>{direction.eyebrow}</p>
          <h3>{direction.title}</h3>
          <span>{direction.summary}</span>
          <small>{direction.count}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-split">
    <div>
      <div class="section-head">
        <p class="eyebrow">Reading Logic</p>
        <h2>The reading flow is tighter now</h2>
      </div>

      <div class="stack">
        <article class="note-card">
          <div class="note-meta">
            <span>Direction 01</span>
            <span>Systems / tools / environment loops</span>
          </div>
          <h3><a href="/notes/agent">LLM Agents</a></h3>
          <p>Everything directly related to agent structure, tool execution, and feedback loops lives here.</p>
        </article>

        <article class="note-card">
          <div class="note-meta">
            <span>Direction 02</span>
            <span>Math / PPO / DPO / GRPO</span>
          </div>
          <h3><a href="/notes/reinforcement-learning">Reinforcement Learning</a></h3>
          <p>Stage 1-6, RLHF, GRPO, RLVR, and post-training engineering all stay on one route.</p>
        </article>

        <article class="note-card">
          <div class="note-meta">
            <span>Direction 03</span>
            <span>Recall / ranking / multi-objective</span>
          </div>
          <h3><a href="/notes/recommendation">Recommendation Systems</a></h3>
          <p>This track now has staged notes, interview review material, and Markdown practice files with a stable landing area.</p>
        </article>
      </div>
    </div>

    <div>
      <div class="section-head">
        <p class="eyebrow">Workflow</p>
        <h2>Use this update loop from now on</h2>
      </div>

      <div class="workflow-card">
        <ol>
          <li>Decide which of the three directions a new file belongs to.</li>
          <li>Drop the raw HTML or Markdown into the archive.</li>
          <li>If it matters long-term, add a direction page entry for it.</li>
          <li>Push to GitHub and let the site update automatically.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Recent Materials</p>
      <h2>Current entry points</h2>
    </div>

    <div class="resource-grid">
      {recentResources.map((item) => (
        <article class="resource-card">
          <div class="resource-meta">
            <span>{item.direction}</span>
            <span>{item.updated}</span>
          </div>
          <h3><a href={item.href} target="_blank" rel="noreferrer">{item.title}</a></h3>
          <p>{item.summary}</p>
          <small>{item.type}</small>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
