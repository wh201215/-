---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { directions } from "../../data/site";
---

<BaseLayout title="Directions" description="The site is currently limited to three fixed directions.">
  <section class="page-intro">
    <p class="eyebrow">Directions</p>
    <h1>Three fixed tracks</h1>
    <p>
      The site is intentionally compact for now. Everything should be sorted into these three directions before you split into smaller subtopics.
    </p>
  </section>

  <section class="card-grid">
    {directions.map((direction) => (
      <a class="feature-card" href={direction.href}>
        <p>{direction.eyebrow}</p>
        <h2>{direction.title}</h2>
        <span>{direction.summary}</span>
        <small>{direction.tags.join(" / ")}</small>
      </a>
    ))}
  </section>
</BaseLayout>
